<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base obsidian background layer -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0A0B0E" />
        </shape>
    </item>
    <!-- Foreground branding icon, padded by 10% (16dp) to prevent rounded corners clipping -->
    <item
        android:drawable="@drawable/ic_launcher_foreground"
        android:top="16dp"
        android:bottom="16dp"
        android:left="16dp"
        android:right="16dp" />
</layer-list>
